  <!-- Icons for install app -->
  <link rel="apple-touch-icon" href="https://creedarcade.github.io/icons/icon-192.png">
  
  <!-- Open Graph / Social -->
  <meta property="og:title" content="Creed Arcade – Play & Download Games">
